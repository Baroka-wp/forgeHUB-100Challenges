{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and progress tracking",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "completedChapters": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of chapter IDs completed by the user"
        },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "lastLogin": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "DossierEntry": {
      "title": "Dossier Entry",
      "description": "An entry in the entrepreneur's dossier corresponding to a chapter exercise",
      "type": "object",
      "properties": {
        "chapterId": { "type": "string" },
        "answers": { 
          "type": "object", 
          "description": "Map of question indices to rich text answers" 
        },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["chapterId", "answers"]
    },
    "Event": {
      "title": "Event",
      "description": "An event created by the admin (webinar, masterclass, etc.)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "location": { "type": "string" },
        "locationType": { "type": "string", "enum": ["presentiel", "webinaire"] },
        "date": { "type": "string", "format": "date-time" },
        "coverImage": { "type": "string" },
        "registrationUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "description", "locationType", "date"]
    },
    "EventRegistration": {
      "title": "Event Registration",
      "description": "User registration for an event",
      "type": "object",
      "properties": {
        "eventId": { "type": "string" },
        "userId": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "whatsapp": { "type": "string" },
        "registeredAt": { "type": "string", "format": "date-time" }
      },
      "required": ["eventId", "userId", "email", "whatsapp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile and progress"
    },
    "/users/{userId}/dossier/{chapterId}": {
      "schema": "DossierEntry",
      "description": "Entrepreneur's dossier entries"
    },
    "/events/{eventId}": {
      "schema": "Event",
      "description": "Events created by admins"
    },
    "/eventRegistrations/{registrationId}": {
      "schema": "EventRegistration",
      "description": "User registrations for events"
    }
  }
}
